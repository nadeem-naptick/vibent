# =============================================================================
# Agentic Collaboration Room — environment template
# Copy to .env and fill in your values. .env is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Postgres (relational: users, rooms, participants, tasks, versions)
# Local dev: postgresql://user:pass@localhost:5432/agentic_room
# UAT: postgresql://user:pass@13.204.177.162:5432/agentic_room
DATABASE_URL=postgresql://user:pass@localhost:5432/agentic_room

# MongoDB (high-write append-only: transcript chunks, agent activity logs)
# Already running at the UAT box; for local dev, run a local mongod or point at UAT
MONGODB_URI=mongodb://13.204.177.162:27017/agentic_room
MONGODB_DB_NAME=agentic_room

# -----------------------------------------------------------------------------
# LiveKit (video room + Agents framework)
# Sign up at https://cloud.livekit.io — free tier covers dev
# -----------------------------------------------------------------------------

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# Public-facing LiveKit URL — used by the browser to connect
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# -----------------------------------------------------------------------------
# Speech-to-Text (transcription with speaker diarization)
# -----------------------------------------------------------------------------

# Deepgram — https://console.deepgram.com
DEEPGRAM_API_KEY=

# -----------------------------------------------------------------------------
# Auth (NextAuth / Auth.js v5)
# -----------------------------------------------------------------------------

# openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:5173

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (magic-link emails) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# AI providers (intelligence-layer modular: Vercel AI SDK routes any of these)
# Need at least ANTHROPIC_API_KEY for the default Claude Haiku 4.5 classifier
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Sandbox provider (per-Room workspace where Claude Code CLI runs)
# Choose vercel OR e2b
# -----------------------------------------------------------------------------

SANDBOX_PROVIDER=vercel

# Vercel Sandbox auth — option A: OIDC (recommended for dev)
# Run `vercel link` then `vercel env pull` to populate automatically
VERCEL_OIDC_TOKEN=

# Vercel Sandbox auth — option B: Personal token (for production)
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_ID=
# VERCEL_TOKEN=

# E2B Sandbox — https://e2b.dev
E2B_API_KEY=

# -----------------------------------------------------------------------------
# Firecrawl (web scraping for "reference website" context input)
# -----------------------------------------------------------------------------

FIRECRAWL_API_KEY=

# -----------------------------------------------------------------------------
# Snapshot storage (per-version sandbox file trees)
# -----------------------------------------------------------------------------

# Driver: 'local' for ~/.agentic-snapshots, 's3' to use S3. If SNAPSHOT_BUCKET
# is set and driver is unset, defaults to 's3'.
# SNAPSHOT_STORE=s3

# S3 config. Local dev uses default AWS credential chain (~/.aws/credentials
# or env vars); EC2 uses the attached IAM role.
SNAPSHOT_BUCKET=vibent-snapshots
SNAPSHOT_PREFIX=snapshots
AWS_REGION=ap-south-1

# Only needed if not using ~/.aws/credentials or an instance role:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# App configuration
# -----------------------------------------------------------------------------

# Port the Next.js dev server binds to
PORT=5173
